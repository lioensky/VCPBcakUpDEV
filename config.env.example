# --- VCP 备份系统配置文件示例 ---

# [路径配置]
# 前端项目路径 (VCPChat 根目录)
VchatUrl=H:\VCP\VCPChat

# 后端项目路径 (支持 Windows 局域网路径)
VCPUrl=\\网络设备\VCP\VCPServer

# [备份选项]
# 是否备份前端附加文件/缓存文件 (attachments, tts_cache)
# 设置为 true 会显著增加备份体积
VchatCache=false

# [坚果云 WebDAV 配置]
# 是否开启坚果云自动上传/下载功能
JianguoyunDEV=true

# 坚果云 WebDAV 服务器地址 (通常不需要修改)
JianguoyunDEVUrl=https://dav.jianguoyun.com/dav/

# 坚果云账号 (邮箱)
JianguoyunDEVUser=your_email@example.com

# 坚果云应用密码 (注意：不是登录密码，需在坚果云后台生成)
JianguoyunDEVPW=your_app_password

# 坚果云上的备份目录
JianguoyunPath=/VCP备份